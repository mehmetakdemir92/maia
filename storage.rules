// Firebase Console > Storage > Rules'a yapıştırıp "Publish" tıkla.
// Uygulama path: users/{uid}/profile.jpg
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Cloud TTS ile üretilen kelime telaffuzları (yazma yalnızca Admin SDK)
    match /pronunciations/{locale}/{fileName} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
