        }
      }
    },
    "Premium removes ads, unlocks AI sentence correction, extra examples, and full profile stats (quiz achievement, max streak)." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Premium entfernt Werbung, schaltet KI-Satzkorrektur, zusätzliche Beispiele und vollständige Profilstatistiken (Quiz-Erfolge, maximale Serie) frei."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Premium elimina los anuncios, desbloquea la corrección de frases con IA, ejemplos adicionales y estadísticas completas del perfil (logros de cuestionario, racha máxima)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Premium supprime les publicités, débloque la correction de phrases par IA, des exemples supplémentaires et des statistiques de profil complètes (réussite des quiz, série maximale)."
