    "Couldn’t generate an example right now. Please try again." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es konnte gerade kein Beispiel generiert werden. Bitte versuchen Sie es erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudo generar un ejemplo en este momento. Inténtalo de nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossible de générer un exemple pour le moment. Veuillez réessayer."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Şu anda bir örnek oluşturulamadı. Lütfen tekrar dene."
          }
        }
      }
    },
    "Couldn’t load today’s words for this level. Tap Try Again or pick a nearby level in Settings." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die heutigen Wörter für dieses Niveau konnten nicht geladen werden. Tippen Sie auf „Erneut versuchen“ oder wählen Sie ein benachbartes Niveau in den Einstellungen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudieron cargar las palabras de hoy para este nivel. Toca Reintentar o elige un nivel cercano en Ajustes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossible de charger les mots du jour pour ce niveau. Appuyez sur Réessayer ou choisissez un niveau proche dans les Réglages."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu seviye için bugünün kelimeleri yüklenemedi. Tekrar Dene'ye dokun veya Ayarlar'dan yakın bir seviye seç."
          }
        }
      }
    },
    "Couldn't load today's words. Check your connection, then tap Try Again." : {

    },
    "Couldn’t load words from the server. Pull to refresh or tap Try Again. If it persists, sign out and sign back in." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wörter konnten nicht vom Server geladen werden. Zum Aktualisieren ziehen oder auf „Erneut versuchen“ tippen. Wenn das Problem weiterhin besteht, melden Sie sich ab und wieder an."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudieron cargar las palabras del servidor. Desliza para actualizar o toca Reintentar. Si el problema persiste, cierra sesión y vuelve a iniciarla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossible de charger les mots depuis le serveur. Tirez pour actualiser ou appuyez sur Réessayer. Si le problème persiste, déconnectez-vous et reconnectez-vous."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sunucudan kelimeler yüklenemedi. Yenilemek için aşağı çek veya Tekrar Dene'ye dokun. Sorun devam ederse, çıkış yapıp tekrar giriş yap."
          }
        }
      }
    },
    "Couldn’t save your diary to the cloud. Check that you’re signed in." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr Tagebuch konnte nicht in der Cloud gespeichert werden. Prüfen Sie, ob Sie angemeldet sind."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudo guardar tu diario en la nube. Comprueba que hayas iniciado sesión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Impossible d'enregistrer votre journal sur le cloud. Vérifiez que vous êtes connecté(e)."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Günlüğün buluta kaydedilemedi. Giriş yaptığından emin ol."
          }
        }
      }
    },
    "Couldn’t sync your diary with the cloud. Showing entries saved on this device." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr Tagebuch konnte nicht mit der Cloud synchronisiert werden. Es werden Einträge angezeigt, die auf diesem Gerät gespeichert sind."
          }
        },
        "es" : {
          "stringUnit" : {
